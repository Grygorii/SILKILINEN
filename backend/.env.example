# SILKILINEN backend — environment variables.
# Copy to `.env` and fill in. Never commit real secrets.

# ── Core (required; server refuses to boot without these) ──
MONGODB_URI=mongodb+srv://user:pass@cluster/silkilinen
JWT_SECRET=                      # ≥32 chars — admin sessions
JWT_CUSTOMER_SECRET=             # customer sessions
PREVIEW_TOKEN_SECRET=            # signs preview links (don't reuse JWT_SECRET)

# ── Stripe ──
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Cloudinary ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (Resend) ──
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL="SILKILINEN <orders@silkilinen.com>"
ADMIN_EMAIL=hello@silkilinen.com   # order notifications + weekly advisor digest

# ── URLs / CORS ──
CORS_ORIGINS=https://www.silkilinen.com,https://silkilinen.com
FRONTEND_URL=https://www.silkilinen.com
BACKEND_URL=https://api.silkilinen.com
BACKEND_PUBLIC_URL=https://api.silkilinen.com
PUBLIC_SITE_URL=https://www.silkilinen.com
SITE_URL=https://www.silkilinen.com
ADMIN_URL=https://www.silkilinen.com/admin

# ── Customer Google sign-in ──
GOOGLE_CLIENT_ID=

# ── Google APIs: Merchant Center (service account) + Search Console (OAuth) ──
GOOGLE_SERVICE_ACCOUNT_KEY=      # full JSON of the service-account key
MERCHANT_ID=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GSC_SITE_URL=sc-domain:silkilinen.com

# IndexNow instant-indexing key (optional). Must match the token served at
# https://www.silkilinen.com/<key>.txt (frontend/public/<key>.txt). Defaults to
# the committed key, so it works with no config; override to rotate the key.
INDEXNOW_KEY=

# ── AI (optional) ──
GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_DAILY_LIMIT=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL_SEO=
FAL_KEY=
FASHN_API_KEY=
FASHN_BASE_URL=
FASHN_MODE=
FASHN_MODEL=

# ── Marketing / integrations (optional) ──
INSTAGRAM_ACCESS_TOKEN=
META_PIXEL_ID=
META_CONVERSIONS_API_TOKEN=
# Pinterest Conversions API (server-side checkout events). Ad account id defaults
# to 549770507607; token is generated in Pinterest → Conversions → Access token.
PINTEREST_AD_ACCOUNT_ID=
PINTEREST_CONVERSION_TOKEN=

# ── Misc ──
LOG_LEVEL=info
PORT=3000

# Atelier screenshots: defaults to free WordPress mShots (no key). Override with a
# paid provider template using {url} and {w} placeholders for higher reliability.
SCREENSHOT_URL_TEMPLATE=
GEMINI_VISION_MODEL=gemini-2.5-flash
